# ──────────────────────────────────────────────────
#  Digital Twin – Environment Variables
#  Copy this file to .env and fill in your own values
# ──────────────────────────────────────────────────

# InfluxDB 2.x initialisation
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-strong-password
INFLUXDB_ORG=digital-twin
INFLUXDB_BUCKET=room_sensors
INFLUXDB_TOKEN=change-me-long-random-token

# Grafana admin account
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password
