# Normalize line endings for cross-platform consistency
* text=auto

# Force LF for files that must not have CRLF
*.py text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.conf text eol=lf
*.txt text eol=lf
*.html text eol=lf

# Binaries
*.png binary
*.jpg binary
*.gif binary
